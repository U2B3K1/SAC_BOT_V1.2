# =============================================
# RESTORAN BOSHQARUV TIZIMI — .env konfiguratsiya
# Bu faylni nusxalab .env deb nomlang va qiymatlarni to'ldiring
# =============================================

# --- Supabase ---
# supabase.com > Project > Settings > API dan oling
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- JWT Settings ---
# Ixtiyoriy uzun va murakkab parol yozing
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Telegram Bot ---
# @BotFather dan oling: /newbot
TELEGRAM_BOT_TOKEN=123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- OpenAI ---
# platform.openai.com > API Keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- SMS (Eskiz.uz) ---
# my.eskiz.uz dan ro'yxatdan o'ting
ESKIZ_EMAIL=your@email.com
ESKIZ_PASSWORD=your_eskiz_password
ESKIZ_SENDER_ID=4546

# --- Redis (Celery uchun) ---
REDIS_URL=redis://localhost:6379/0

# --- App Settings ---
APP_NAME=Restoran Boshqaruv Tizimi
DEBUG=True
ALLOWED_ORIGINS=http://localhost:5173,https://your-domain.com
